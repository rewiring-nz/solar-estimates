# This config is designed for a fast run, with minimal key days, and large time steps.

# Required
INPUT_DSM_GLOB=data/inputs/DSM/suburb_ShotoverCountry/*.tif
INPUT_BUILDING_DIR=data/inputs/building_outlines/district_QueenstownLakes
OUTPUT_AREA_NAME=suburb_ShotoverCountry
OUTPUT_BUILDING_LAYER_NAME=queenstown_lakes_buildings

# Optional: Processing parameters (uncomment to override defaults)
OUTPUT_PREFIX=solar_on_buildings
MAX_SLOPE=45.0
KEY_DAYS=1
TIME_STEP=3.0
EXPORT_RASTERS=true  # any non-empty value enables raster export; leave unset (commented out) to disable

# Optional: Horizon parameters (for shading pre-calculation)
CALCULATE_HORIZON=true        # Uncomment to enable horizon pre-calculation (default: disabled)
DSM_BUFFER_DISTANCE=3         # Local horizon search radius in meters (1m DSM)
DEM_BUFFER_DISTANCE=10        # Regional horizon search radius in meters (8m DEM)
HORIZON_STEP_DEGREES=180      # Number of degrees to step around horizon
HORIZON_START_AZIMUTH=0       # Start azimuth in degrees
HORIZON_END_AZIMUTH=360       # End azimuth in degrees

# Glob pattern for optional 8m DEM tiles (regional horizon), initially pointing to our DSM
INPUT_DEM_GLOB=data/inputs/DSM/suburb_ShotoverCountry/*.tif 

# Optional: WRF data (weather adjustment)
# WRF_FILE=
# SOURCE_CRS=EPSG:4326
# TARGET_CRS=EPSG:2193