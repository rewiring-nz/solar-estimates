# Required
INPUT_DSM_GLOB=data/inputs/DSM/suburb_ShotoverCountry/*.tif
INPUT_BUILDING_DIR=data/inputs/building_outlines/district_QueenstownLakes
OUTPUT_AREA_NAME=suburb_ShotoverCountry
OUTPUT_BUILDING_LAYER_NAME=queenstown_lakes_buildings

# Optional: Processing parameters (uncomment to override defaults)
# OUTPUT_PREFIX=solar_on_buildings
# MAX_SLOPE=45.0
# KEY_DAYS=1 7
# TIME_STEP=1.0
# EXPORT_RASTERS=true  # any non-empty value enables raster export; leave unset (commented out) to disable

# Optional: WRF data (weather adjustment)
# WRF_FILE=
# SOURCE_CRS=EPSG:4326
# TARGET_CRS=EPSG:2193

# Optional: Horizon pre-calculation (improves accuracy by accounting for terrain shading)
# CALCULATE_HORIZON=true  # any non-empty value enables horizon pre-calculation; leave unset to disable
# DSM_BUFFER_DISTANCE=1000.0   # max search distance (m) for local (DSM) horizon
# DEM_BUFFER_DISTANCE=50000.0  # max search distance (m) for regional (DEM) horizon
# HORIZON_AZIMUTH_STEPS=16     # number of azimuth directions to compute
# HORIZON_START_AZIMUTH=0.0    # start azimuth in degrees
# HORIZON_END_AZIMUTH=360.0    # end azimuth in degrees
# INPUT_DEM_GLOB=data/inputs/DEM/*.tif  # glob for DEM tiles (enables regional horizon; leave unset for local-only)