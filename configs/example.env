# Example pipeline configuration
#
# Usage:
#   docker compose --env-file configs/example.env up pipeline
#   PIPELINE_EXPORT_RASTERS=true python src/pipeline.py
#
# All variables use the PIPELINE_ prefix and map directly to pipeline.py CLI arguments.
# CLI arguments always take precedence over environment variables.
#
# Paths are relative to the WORKDIR (/app/src inside Docker, or src/ when running locally).

# ---------------------------------------------------------------------------
# Required inputs
# ---------------------------------------------------------------------------

# Glob pattern for input DSM GeoTIFF files
PIPELINE_DSM_GLOB=data/inputs/DSM/suburb_ShotoverCountry/*.tif

# Directory containing building outline shapefiles
PIPELINE_BUILDING_DIR=data/inputs/building_outlines/district_QueenstownLakes

# ---------------------------------------------------------------------------
# Output naming
# ---------------------------------------------------------------------------

# Descriptive name for the area (used in output filenames)
PIPELINE_AREA_NAME=suburb_ShotoverCountry

# Name of the output building outline layer
PIPELINE_BUILDING_LAYER_NAME=queenstown_lakes_buildings

# Prefix for output files (default: solar_on_buildings)
# PIPELINE_OUTPUT_PREFIX=solar_on_buildings

# ---------------------------------------------------------------------------
# Processing parameters
# ---------------------------------------------------------------------------

# Maximum slope in degrees for filtering (default: 45.0)
# PIPELINE_MAX_SLOPE=45.0

# Day-of-year numbers for solar irradiance interpolation, space-separated (default: 1 7)
# PIPELINE_KEY_DAYS=1 7

# Time step in decimal hours for all-day radiation sums (default: 1.0)
# PIPELINE_TIME_STEP=1.0

# Export rasters (solar irradiance, coefficient, WRF adjusted, final) as GeoTIFFs
# Set to true, 1, or yes to enable (default: false)
# PIPELINE_EXPORT_RASTERS=false

# ---------------------------------------------------------------------------
# GRASS GIS
# ---------------------------------------------------------------------------

# Path to GRASS GIS installation base directory (auto-detected if not set)
# PIPELINE_GRASS_BASE=/usr/lib/grass84

# ---------------------------------------------------------------------------
# WRF weather data (optional)
# ---------------------------------------------------------------------------

# Path to WRF NetCDF file for measured radiation data
# PIPELINE_WRF_FILE=data/inputs/weather/swdown_2016-2020_daily_mean_doy.nc

# Source CRS for WRF data (default: EPSG:4326)
# PIPELINE_SOURCE_CRS=EPSG:4326

# Target CRS for WRF reprojection (default: EPSG:2193 - NZGD2000)
# PIPELINE_TARGET_CRS=EPSG:2193
